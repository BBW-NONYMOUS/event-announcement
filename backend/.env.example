DATABASE_URL=postgresql://postgres:password@localhost:5432/event_checkin
SECRET_KEY=change-me-to-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=1440
CORS_ORIGINS=http://localhost:5173,http://localhost:8081

# Event image uploads. UPLOAD_DIR is relative to backend/ unless absolute;
# files are served at /uploads. Only PNG, JPG, and WebP are accepted.
UPLOAD_DIR=uploads
MAX_UPLOAD_MB=15

# Used only by pytest — must be a separate database, it is dropped and recreated.
TEST_DATABASE_URL=postgresql://postgres:password@localhost:5432/event_checkin_test
