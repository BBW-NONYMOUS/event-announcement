DATABASE_URL=postgresql://postgres:password@localhost:5432/event_checkin
SECRET_KEY=change-me-to-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=1440
CORS_ORIGINS=http://localhost:5173,http://localhost:8081

# Event image uploads. UPLOAD_DIR is relative to backend/ unless absolute;
# files are served at /uploads. Only PNG, JPG, and WebP are accepted.
UPLOAD_DIR=uploads
MAX_UPLOAD_MB=15

# S3-compatible object storage (Cloudflare R2) for event images.
#
# Leave these unset for development — images go to UPLOAD_DIR, which is what
# the tests use too. In production they are required on any host with an
# ephemeral filesystem, where local files are lost on every redeploy.
#
# All five or none: with any one missing the API falls back to local disk.
# S3_ENDPOINT_URL=https://<account-id>.r2.cloudflarestorage.com
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_BUCKET=event-images
# S3_PUBLIC_URL=https://pub-xxxxx.r2.dev

# Used only by pytest — must be a separate database, it is dropped and recreated.
TEST_DATABASE_URL=postgresql://postgres:password@localhost:5432/event_checkin_test
