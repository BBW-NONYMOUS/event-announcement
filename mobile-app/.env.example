# Copy to .env only if you need to override the automatic dev resolution.
#
# In development the app finds the backend from the Metro host, so this is
# usually unnecessary — set it when the device is on a different network than
# the dev machine, or when pointing at a deployed backend.
#
# Standalone builds (APK/AAB/IPA) have no Metro host, so they REQUIRE this.
# For those, set it in eas.json under the build profile rather than here:
# EXPO_PUBLIC_* values are inlined at build time, and .env is not uploaded to
# EAS Build.
#
# Must be https:// for a release build — Android blocks cleartext HTTP unless
# usesCleartextTraffic is enabled, and that is set only for debug builds.
EXPO_PUBLIC_API_URL=http://192.168.1.10:8000
